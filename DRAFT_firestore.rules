rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Hardcoded initial admin based on user email
      return isEmailVerified() && (
        request.auth.token.email == 'bradleyjsmithuk@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Battle Validation ---
    function isValidBattle(data) {
      return data.keys().hasAll(['title', 'artistA', 'artistB', 'status', 'votesA', 'votesB', 'createdAt', 'updatedAt'])
        && data.keys().size() == 8
        && data.title is string && data.title.size() <= 200
        && data.artistA is string && data.artistA.size() <= 100
        && data.artistB is string && data.artistB.size() <= 100
        && data.status in ['pending', 'active', 'finished']
        && data.votesA is int && data.votesA >= 0
        && data.votesB is int && data.votesB >= 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // --- Vote Validation ---
    function isValidVote(data) {
      return data.keys().hasAll(['battleId', 'voterId', 'choice', 'timestamp'])
        && data.keys().size() == 4
        && isValidId(data.battleId)
        && data.voterId == request.auth.uid
        && data.choice in ['A', 'B']
        && data.timestamp == request.time;
    }

    // --- Rules ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed manually or by existing admins
    }

    match /battles/{battleId} {
      allow read: if true; // Public can see active battles and results
      
      allow create: if isAdmin() && isValidBattle(incoming()) 
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().votesA == 0
        && incoming().votesB == 0;

      allow update: if (
        (isAdmin() && isValidBattle(incoming()) && incoming().updatedAt == request.time) ||
        // Atomicity Guarantee: When a vote is created, the tally must increment.
        // This is paired with the vote creation rule.
        (isSignedIn() && isValidBattle(incoming()) && (
          // Action: Vote A
          (incoming().diff(existing()).affectedKeys().hasOnly(['votesA', 'updatedAt']) && 
           incoming().votesA == existing().votesA + 1 && 
           get(/databases/$(database)/documents/votes/$(request.auth.uid + '_' + battleId)).data.choice == 'A') ||
          // Action: Vote B
          (incoming().diff(existing()).affectedKeys().hasOnly(['votesB', 'updatedAt']) && 
           incoming().votesB == existing().votesB + 1 &&
           get(/databases/$(database)/documents/votes/$(request.auth.uid + '_' + battleId)).data.choice == 'B')
        ))
      );
    }

    match /votes/{voteId} {
      // voteId should be voterId + "_" + battleId
      allow get: if isSignedIn() && resource.data.voterId == request.auth.uid;
      allow list: if false; // Don't allow listing all votes

      allow create: if isSignedIn() 
        && voteId == request.auth.uid + '_' + incoming().battleId
        && isValidVote(incoming())
        && get(/databases/$(database)/documents/battles/$(incoming().battleId)).data.status == 'active'
        && existsAfter(/databases/$(database)/documents/battles/$(incoming().battleId));
        // Note: The atomic increment is enforced by the Battle update rule needing this document.
    }
  }
}
